<ui:FluentWindow
    x:Class="Klip.App.Windows.HistoryFlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:Klip.App.Localization"
    xmlns:controls="clr-namespace:Klip.App.Controls"
    xmlns:vm="clr-namespace:Klip.App.ViewModels"
    Title="Klip"
    Width="360"
    Height="460"
    MinWidth="360"
    MinHeight="460"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="Manual"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    ShowActivated="False"
    Topmost="True">
    <ui:FluentWindow.Resources>
        <Style x:Key="TabRadioStyle" TargetType="RadioButton">
            <!-- Glifos herdam o foreground do tema (TextElement.Foreground é herdado) -->
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="Pill"
                            Padding="10,6"
                            Background="Transparent"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bg"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Emoji cell: flat, fills its grid cell, subtle hover like the native panel -->
        <Style x:Key="EmojiButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Margin="8" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Strip de abas por ícone (estilo painel de emoji nativo) -->
        <Grid Grid.Row="0" Margin="4,4,4,4">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="TabRecent" GroupName="Tabs" Style="{StaticResource TabRadioStyle}" ToolTip="{DynamicResource Loc.TabRecent}" IsChecked="True">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE81C;" />
                </RadioButton>
                <RadioButton x:Name="TabFavorites" GroupName="Tabs" Style="{StaticResource TabRadioStyle}" ToolTip="{DynamicResource Loc.TabFavorites}">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE734;" />
                </RadioButton>
                <RadioButton x:Name="TabImages" GroupName="Tabs" Style="{StaticResource TabRadioStyle}" ToolTip="{DynamicResource Loc.TabImages}">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE91B;" />
                </RadioButton>
                <RadioButton x:Name="TabText" GroupName="Tabs" Style="{StaticResource TabRadioStyle}" ToolTip="{DynamicResource Loc.TabText}">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE8D2;" />
                </RadioButton>
                <RadioButton x:Name="TabFiles" GroupName="Tabs" Style="{StaticResource TabRadioStyle}" ToolTip="{DynamicResource Loc.TabFiles}">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE7C3;" />
                </RadioButton>
                <RadioButton x:Name="TabEmoji" GroupName="Tabs" Style="{StaticResource TabRadioStyle}" ToolTip="{DynamicResource Loc.TabEmoji}">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE76E;" />
                </RadioButton>
            </StackPanel>
            <Button
                x:Name="MultiSelectButton"
                HorizontalAlignment="Right"
                Margin="0,0,40,0"
                Style="{StaticResource CardActionButton}"
                Padding="10,6"
                ToolTip="{DynamicResource Loc.MultiPasteTooltip}">
                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE762;" />
                <Button.ContextMenu>
                    <ContextMenu x:Name="MultiSelectMenu" />
                </Button.ContextMenu>
            </Button>
            <Button
                x:Name="DateFilterButton"
                HorizontalAlignment="Right"
                Style="{StaticResource CardActionButton}"
                Padding="10,6"
                ToolTip="{DynamicResource Loc.FilterByDate}">
                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE787;" />
                <Button.ContextMenu>
                    <ContextMenu x:Name="DateFilterMenu" />
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- Busca -->
        <ui:TextBox
            x:Name="SearchBox"
            Grid.Row="1"
            Margin="4,0,4,8"
            ClearButtonEnabled="True"
            Icon="{ui:SymbolIcon Search24}"
            PlaceholderText="{DynamicResource Loc.SearchPlaceholder}"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Chip do filtro de data ativo -->
        <Border
            Grid.Row="2"
            Margin="4,0,4,8"
            Padding="8,4"
            HorizontalAlignment="Left"
            Background="{DynamicResource AccentFillColorDefaultBrush}"
            CornerRadius="10"
            Visibility="{Binding HasDateFilter, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    Text="{Binding DateFilterLabel}" />
                <Button
                    Margin="6,0,0,0"
                    Padding="2,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ClearDateFilterCommand}"
                    Cursor="Hand">
                    <TextBlock
                        FontFamily="Segoe Fluent Icons"
                        FontSize="9"
                        Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                        Text="&#xE711;" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Modo seleção múltipla: só as bolinhas numeradas nos cards indicam a ordem;
             fechar ou Enter confirma, Esc cancela. Sem barra nem botões. -->

        <!-- Lista de cards -->
        <ListBox
            x:Name="ItemsList"
            Grid.Row="3"
            Background="Transparent"
            BorderThickness="0"
            FocusVisualStyle="{x:Null}"
            HorizontalContentAlignment="Stretch"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.ScrollChanged="OnListScroll"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.IsVirtualizingWhenGrouping="True"
            VirtualizingPanel.VirtualizationMode="Recycling"
            VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <!-- Container do grupo sem borda nem foco/selecao: o template padrao
                         do tema desenha moldura e torna o cabecalho selecionavel quando
                         ha item fixado. Aqui e so cabecalho (nao interativo) + itens. -->
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <StackPanel>
                                            <ContentPresenter Focusable="False" IsHitTestVisible="False" />
                                            <ItemsPresenter />
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="4,8,0,4"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Focusable="False"
                                IsHitTestVisible="False"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding Name}" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemContainerStyle>
                <!-- Seleção estilo Win11: fill sutil + indicador accent à esquerda
                     (nunca o azul chapado do WPF clássico) -->
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0,0,0,4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid>
                                    <Border
                                        x:Name="Bg"
                                        Background="Transparent"
                                        CornerRadius="4">
                                        <ContentPresenter />
                                    </Border>
                                    <Rectangle
                                        x:Name="Indicator"
                                        Width="3"
                                        Margin="0,10,0,10"
                                        HorizontalAlignment="Left"
                                        Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                        RadiusX="1.5"
                                        RadiusY="1.5"
                                        Visibility="Collapsed" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:HistoryItemViewModel}">
                    <!-- Card -->
                    <Border
                        Padding="12"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Badge de ordem na fila de colagem -->
                            <Border
                                Grid.Row="0"
                                Panel.ZIndex="10"
                                Width="20" Height="20"
                                Margin="0,-2,-2,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="10"
                                Visibility="{Binding IsQueued, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                    Text="{Binding QueueOrder}" />
                            </Border>

                            <!-- Conteúdo -->
                            <Grid Grid.Row="0">
                                <TextBlock
                                    MaxHeight="72"
                                    FontSize="13"
                                    Text="{Binding PreviewText, Mode=OneTime}"
                                    TextTrimming="None"
                                    TextWrapping="Wrap"
                                    Visibility="{Binding ShowsTextPreview, Mode=OneTime, Converter={StaticResource BoolToVisibility}}" />
                                <Image
                                    MaxHeight="96"
                                    HorizontalAlignment="Left"
                                    Source="{Binding ThumbSource, Mode=OneTime, Converter={StaticResource PathToThumbnail}}"
                                    Stretch="Uniform"
                                    StretchDirection="DownOnly"
                                    Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}" />
                                <!-- RF-F4.05: GIF mostra o primeiro frame e anima só com o mouse sobre o card -->
                                <controls:HoverGifPlayer
                                    MaxHeight="96"
                                    HorizontalAlignment="Left"
                                    SourcePath="{Binding MediaFilePath, Mode=OneTime}"
                                    Stretch="Uniform"
                                    StretchDirection="DownOnly"
                                    Visibility="{Binding IsGifMedia, Mode=OneTime, Converter={StaticResource BoolToVisibility}}" />
                                <!-- MP4: glifo de vídeo como placeholder, sem decode de vídeo -->
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="40"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="&#xE714;"
                                    Visibility="{Binding IsMp4Media, Mode=OneTime, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>

                            <!-- Metadados + ações -->
                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,6,0"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{Binding TypeGlyph, Mode=OneTime}" />
                                    <TextBlock
                                        FontSize="11"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{Binding MetaLine, Mode=OneTime}" />
                                    <TextBlock
                                        Margin="6,0,0,0"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                        Text="&#xE840;"
                                        ToolTip="{DynamicResource Loc.PinnedBadge}"
                                        Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                        Text="&#xE735;"
                                        ToolTip="{DynamicResource Loc.FavoriteBadge}"
                                        Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button Click="OnPinClick" Style="{StaticResource CardActionButton}" ToolTip="{DynamicResource Loc.PinTooltip}">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="&#xE718;" />
                                    </Button>
                                    <Button Click="OnFavoriteClick" Style="{StaticResource CardActionButton}" ToolTip="{DynamicResource Loc.FavoriteTooltip}">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="&#xE734;" />
                                    </Button>
                                    <Button Click="OnMoreClick" Style="{StaticResource CardActionButton}" ToolTip="{DynamicResource Loc.MoreOptions}">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="&#xE712;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Estado vazio -->
        <StackPanel
            Grid.Row="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
            <TextBlock
                FontFamily="Segoe Fluent Icons"
                FontSize="32"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="&#xE8C8;" />
            <TextBlock
                Margin="0,8,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{DynamicResource Loc.EmptyHistory}" />
        </StackPanel>

        <!-- Painel de emoji (aparece quando a aba de emoji esta ativa) -->
        <Grid x:Name="EmojiPanel" Grid.Row="3" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ui:TextBox
                x:Name="EmojiSearchBox"
                Grid.Row="0"
                Margin="0,0,0,6"
                Icon="{ui:SymbolIcon Search24}"
                PlaceholderText="{DynamicResource Loc.EmojiSearchPlaceholder}" />
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="EmojiWrap" Margin="0,0,2,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
            <!-- Categorias -->
            <Border Grid.Row="2" Margin="0,4,0,0" Padding="2"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4">
                <StackPanel x:Name="EmojiCategories" Orientation="Horizontal" HorizontalAlignment="Center" />
            </Border>
        </Grid>

        <!-- Rodapé -->
        <Grid Grid.Row="4" Margin="4,6,4,2">
            <TextBlock
                FontSize="11"
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                Text="{DynamicResource Loc.FooterHints}" />
            <ui:Button
                x:Name="ClearAllButton"
                HorizontalAlignment="Right"
                Padding="8,4"
                Appearance="Transparent"
                Content="{DynamicResource Loc.ClearAll}"
                FontSize="12"
                ToolTip="{DynamicResource Loc.ClearAllTooltip}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
