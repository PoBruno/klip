<ui:FluentWindow
    x:Class="Klip.App.Windows.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:Klip.App.Localization"
    Title="Klip"
    Width="560"
    Height="560"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">
    <Grid TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Klip" />

        <StackPanel Grid.Row="1" Margin="32,16,32,0">
            <TextBlock
                FontFamily="Segoe Fluent Icons"
                FontSize="44"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                Text="&#xE81C;" />
            <TextBlock
                Margin="0,12,0,4"
                FontSize="24"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                Text="{DynamicResource Loc.OnboardWelcomeTitle}" />
            <TextBlock
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{DynamicResource Loc.OnboardWelcomeSubtitle}" />

            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16,12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="{DynamicResource Loc.OnboardShortcutsTitle}" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,10,6" Padding="8,3" Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                            <TextBlock Text="Ctrl+Shift+V" FontFamily="Consolas" />
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="{DynamicResource Loc.OnboardHistoryDesc}" />
                        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" Padding="8,3" Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                            <TextBlock Text="Ctrl+Shift+S" FontFamily="Consolas" />
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="{DynamicResource Loc.OnboardCaptureDesc}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16,12">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="{DynamicResource Loc.OnboardWinVTitle}" Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{DynamicResource Loc.OnboardWinVDesc}" />
                    <ui:Button x:Name="TakeWinVButton" Margin="0,10,0,0" Appearance="Primary" Content="{DynamicResource Loc.TakeWinV}" />
                    <TextBlock x:Name="WinVResult" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2" Margin="32,16,32,24">
            <ui:Button x:Name="FinishButton" HorizontalAlignment="Right" Appearance="Primary" Content="{DynamicResource Loc.OnboardFinish}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
