<ui:FluentWindow
    x:Class="Klip.App.Windows.EditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:Klip.App.Localization"
    Title="{DynamicResource Loc.EditorTitle}"
    Width="1000"
    Height="720"
    MinWidth="720"
    MinHeight="480"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <Style x:Key="ToolButton" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Bg"
                            Padding="10,8"
                            Margin="1,0"
                            Background="Transparent"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bg"
                            Padding="10,8"
                            Margin="1,0"
                            Background="Transparent"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Glyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <!-- Emoji cell: flat, fills its grid cell, subtle hover -->
        <Style x:Key="EmojiButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Swatch" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="22" Height="22">
                            <Ellipse
                                x:Name="Ring"
                                Stroke="Transparent"
                                StrokeThickness="2" />
                            <Ellipse
                                Margin="4"
                                Fill="{TemplateBinding Background}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource Loc.EditorTitle}" />

        <!-- Toolbar: tools scroll horizontally if space runs out, actions stay pinned right -->
        <Grid Grid.Row="1" Margin="12,4,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <ToggleButton x:Name="ToolSelect" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolSelect}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE7C9;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolPen" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolPen}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE76D;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolHighlighter" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolHighlighter}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE7E6;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolEraser" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolEraser}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE75C;" />
                    </ToggleButton>
                    <Border Width="1" Margin="6,8" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                    <ToggleButton x:Name="ToolRect" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolRect}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE739;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolEllipse" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolEllipse}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xEA3A;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolLine" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolLine}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE738;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolArrow" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolArrow}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xF0AF;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolText" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolText}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE8D2;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolEmoji" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolEmoji}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE76E;" />
                    </ToggleButton>
                    <Border Width="1" Margin="6,8" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                    <ToggleButton x:Name="ToolCrop" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolCrop}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE7A8;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolBlur" Style="{StaticResource ToolButton}" ToolTip="{DynamicResource Loc.ToolBlur}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE890;" />
                    </ToggleButton>
                    <Button x:Name="RotateLeftButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolRotateLeft}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE10E;" />
                    </Button>
                    <Button x:Name="RotateRightButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolRotateRight}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE10D;" />
                    </Button>
                    <Button x:Name="RemoveBgButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolRemoveBg}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xEA99;" />
                    </Button>
                    <Button x:Name="TextActionsButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolTextActions}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE8E9;" />
                    </Button>
                    <Button x:Name="QuickRedactButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolQuickRedact}">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xED1A;" />
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Column="1" Margin="8,0,0,0" Orientation="Horizontal"
                        Background="{DynamicResource ApplicationBackgroundBrush}">
                <Border Width="1" Margin="0,8,6,8" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                <Button x:Name="UndoButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolUndo}">
                    <TextBlock Style="{StaticResource Glyph}" Text="&#xE7A7;" />
                </Button>
                <Button x:Name="RedoButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolRedo}">
                    <TextBlock Style="{StaticResource Glyph}" Text="&#xE7A6;" />
                </Button>
                <Border Width="1" Margin="6,8" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                <ToggleButton x:Name="AutoCopyToggle" IsChecked="True" Style="{StaticResource ToolButton}"
                              ToolTip="{DynamicResource Loc.ToolAutoCopy}">
                    <TextBlock Style="{StaticResource Glyph}" Text="&#xE8C8;" />
                </ToggleButton>
                <Button x:Name="SaveButton" Style="{StaticResource ActionButton}" ToolTip="{DynamicResource Loc.ToolSaveAs}">
                    <TextBlock Style="{StaticResource Glyph}" Text="&#xE792;" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Barra de propriedades: cores + espessura (linha própria, abaixo das ferramentas) -->
        <StackPanel
            x:Name="PropertiesBar"
            Grid.Row="2"
            Margin="12,2,12,8"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <RadioButton x:Name="SwRed" Background="#FF4040" GroupName="Colors" IsChecked="True" Style="{StaticResource Swatch}" />
            <RadioButton Background="#FFB900" GroupName="Colors" Style="{StaticResource Swatch}" />
            <RadioButton Background="#10C060" GroupName="Colors" Style="{StaticResource Swatch}" />
            <RadioButton Background="#0078D4" GroupName="Colors" Style="{StaticResource Swatch}" />
            <RadioButton Background="#B146C2" GroupName="Colors" Style="{StaticResource Swatch}" />
            <RadioButton Background="#000000" GroupName="Colors" Style="{StaticResource Swatch}" />
            <RadioButton Background="#FFFFFF" GroupName="Colors" Style="{StaticResource Swatch}" />
            <Border Width="1" Margin="8,2" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
            <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{DynamicResource Loc.Thickness}" />
            <Slider x:Name="ThicknessSlider" Width="100" VerticalAlignment="Center"
                    Maximum="16" Minimum="1" Value="3" />
        </StackPanel>

        <!-- Canvas com zoom -->
        <ScrollViewer
            x:Name="CanvasScroll"
            Grid.Row="3"
            Margin="12,8,12,0"
            Background="{DynamicResource ControlFillColorInputActiveBrush}"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ZoomWrapper" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid x:Name="CanvasHost" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image x:Name="BaseImage" Stretch="None" />
                    <InkCanvas
                        x:Name="Ink"
                        Background="Transparent"
                        EditingMode="Ink" />
                    <!-- Retângulo de recorte (só no modo crop) -->
                    <Canvas x:Name="CropLayer" Background="Transparent" IsHitTestVisible="False" Visibility="Collapsed">
                        <Rectangle
                            x:Name="CropRect"
                            Stroke="White"
                            StrokeDashArray="4 3"
                            StrokeThickness="2"
                            Fill="#30FFFFFF" />
                    </Canvas>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Status -->
        <Grid Grid.Row="4" Margin="12,6,12,8">
            <TextBlock
                x:Name="StatusText"
                VerticalAlignment="Center"
                FontSize="11"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{DynamicResource Loc.Zoom}" />
                <Slider x:Name="ZoomSlider" Width="120" VerticalAlignment="Center"
                        Maximum="4" Minimum="0.1" Value="1" />
                <TextBlock x:Name="ZoomLabel" Width="42" Margin="8,0,0,0" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="100%" />
            </StackPanel>
        </Grid>

        <!-- Emoji picker popup (opens from the emoji tool button) -->
        <Popup x:Name="EmojiPopup" Grid.Row="1" PlacementTarget="{Binding ElementName=ToolEmoji}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Width="320" Height="280" Margin="8"
                    Background="{DynamicResource AcrylicBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" />
                </Border.Effect>
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ui:TextBox x:Name="EmojiPopupSearch" Grid.Row="0" Margin="0,0,0,6"
                                Icon="{ui:SymbolIcon Search24}" PlaceholderText="{DynamicResource Loc.EmojiSearchPlaceholder}" />
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="EmojiPopupWrap">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel x:Name="EmojiPopupCategories" Grid.Row="2" Margin="0,4,0,0"
                                Orientation="Horizontal" HorizontalAlignment="Center" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</ui:FluentWindow>
